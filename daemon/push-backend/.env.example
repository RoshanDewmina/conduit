# Copy to .env for local development. In production (Fly.io): fly secrets set KEY=VALUE
# .env is gitignored; this file is committed as documentation.
#
# ── APNs push notification delivery ──────────────────────────────────────────
APPROVAL_RELAY_SECRET=change-me-strong-random-value
APNS_KEY_ID=XXXXXXXXXX           # 10-char key ID: developer.apple.com → Keys
APNS_TEAM_ID=XXXXXXXXXX          # 10-char team ID: developer.apple.com → Membership
APNS_KEY_PATH=AuthKey_KEYID.p8   # path to the .p8 file downloaded from Apple
APNS_BUNDLE_ID=dev.conduit.mobile

# ── Stripe billing (Conduit Pro subscription) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...          # sk_test_... for testing, sk_live_... for prod
STRIPE_WEBHOOK_SECRET=whsec_...        # Stripe dashboard → Webhooks → signing secret
STRIPE_PRICE_MONTHLY=price_...         # Stripe Price ID for monthly plan
STRIPE_PRICE_ANNUAL=price_...          # Stripe Price ID for annual plan

# ── Entitlements persistence ────────────────────────────────────────────────
# Default: JSON file under DATA_DIR or system temp. Optional Redis override:
ENTITLEMENTS_FILE=/data/conduit-entitlements.json
ENTITLEMENTS_REDIS_URL=redis://:password@host:6379/0
DATA_DIR=/data

# ── Hosted agents control plane ───────────────────────────────────────────────
CONTROL_PLANE_FILE=/data/conduit-control-plane.json
USAGE_FILE=/data/conduit-usage.json
CREDITS_FILE=/data/conduit-credits.json
ARTIFACTS_FILE=/data/conduit-artifacts.json
SCHEDULES_FILE=/data/conduit-schedules.json
GCP_ORCHESTRATION_FILE=/data/conduit-gcp-orchestrations.json
ORGS_FILE=/data/conduit-orgs.json

# Credits (Phase 2)
CREDITS_INITIAL_USD=0
CREDITS_ALLOW_OVERAGE=true

# Artifacts GCS URI prefix (optional; upload still client-side)
GCS_ARTIFACTS_BUCKET=

# Schedules
SCHEDULE_TICKER_ENABLED=true

# GCP Cloud Run Jobs runtime (Phase 2 — stub submit without full GCP client)
GCP_PROJECT=
GCP_REGION=us-central1
GCP_CLOUD_RUN_IMAGE=gcr.io/cloudrun/hello

# Quotas (Phase 3)
QUOTA_MAX_AGENTS=20
QUOTA_MAX_CONCURRENT_RUNS=5
QUOTA_DAILY_USAGE_USD=100

# ── OpenRouter managed AI (provisioning API) ──────────────────────────────────
OPENROUTER_PROVISIONING_KEY=sk-or-v1-...   # Management API key from openrouter.ai/keys
OPENROUTER_BASE_URL=https://openrouter.ai    # default
OPENROUTER_LIMIT_MONTHLY=20                  # USD spend limit for monthly subscribers
OPENROUTER_LIMIT_ANNUAL=50                   # USD spend limit for annual subscribers
OPENROUTER_LIMIT_RESET=monthly               # daily | weekly | monthly

# ── Server URLs (used in Stripe checkout redirect flow) ──────────────────────
PUBLIC_BASE_URL=https://conduit-push.fly.dev    # deployed URL of this backend
WEBSITE_BASE_URL=https://conduit.dev            # marketing site (cancel redirect)

# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=8080                               # default: 8080
CORS_ALLOW_ORIGIN=https://conduit.dev  # default: * — restrict in production
