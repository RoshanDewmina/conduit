# Copy to .env for local development. In production (Fly.io): fly secrets set KEY=VALUE
# .env is gitignored; this file is committed as documentation.
#
# NOTE: billingEntitlements is in-memory only — not persisted across restarts.
# Before production, back it with Redis or a database (see billing.go).

# ── APNs push notification delivery ──────────────────────────────────────────
APNS_KEY_ID=XXXXXXXXXX           # 10-char key ID: developer.apple.com → Keys
APNS_TEAM_ID=XXXXXXXXXX          # 10-char team ID: developer.apple.com → Membership
APNS_KEY_PATH=AuthKey_KEYID.p8   # path to the .p8 file downloaded from Apple
APNS_BUNDLE_ID=dev.conduit.mobile

# ── Stripe billing (Conduit Pro subscription) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...          # sk_test_... for testing, sk_live_... for prod
STRIPE_WEBHOOK_SECRET=whsec_...        # Stripe dashboard → Webhooks → signing secret
STRIPE_PRICE_MONTHLY=price_...         # Stripe Price ID for monthly plan
STRIPE_PRICE_ANNUAL=price_...          # Stripe Price ID for annual plan

# ── Server URLs (used in Stripe checkout redirect flow) ──────────────────────
PUBLIC_BASE_URL=https://conduit-push.fly.dev    # deployed URL of this backend
WEBSITE_BASE_URL=https://conduit.dev            # marketing site (cancel redirect)

# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=8080                               # default: 8080
CORS_ALLOW_ORIGIN=https://conduit.dev  # default: * — restrict in production
