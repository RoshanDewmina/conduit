# Xcode
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
build/

# SwiftPM
.build/
Package.resolved
.swiftpm/

# macOS
.DS_Store

# Playwright MCP cache (tooling artifact, not source)
.playwright-mcp/

# Local secrets
*.env
secrets.plist

# Generated launch screen color
Conduit/Resources/Assets.xcassets/LaunchBackground.colorset/

# Profiling
*.trace
*.instrumentscli
.dmux/

# Local agent scratch worktrees (Claude Code tooling). Skills are handled below.
.claude/worktrees/

# AI agent tooling dotfiles (Claude Code, Cursor, Goose, Kiro, etc.)
# New agents drop a dot-dir at repo root — catch them all with this glob.
.agents/
.codebuddy/
.commandcode/
.continue/
.crush/
.factory/
