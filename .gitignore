.roo/
.trae/
.zencoder/

# Skills / agent lock files (tooling artifacts, not source)
skills-lock.json

# Remotion animation tooling (not shipped in app bundle)
animations/node_modules/

# Push-backend compiled binaries (distributed via GitHub Releases, not git)
daemon/push-backend/push-backend-linux
daemon/push-backend/push-backend

# AI-tool scratch directories (never commit)
.agents/
.codebuddy/
.commandcode/
.continue/
.crush/
.factory/
.goose/
.hermes/
.junie/
.kiro/
.kode/
.mcpjam/
.mux/
.neovate/
.openhands/
.pi/
.pochi/
.qoder/
.qwen/
.playwright-mcp/
.roo/
.trae/
.zencoder/

# Claude Code / superpowers lock file
skills-lock.json

# Claude Code skills: ignore auto-installed/symlinked skills, but TRACK the hand-authored
# Conduit project skills so a clean checkout / teammate / fresh machine gets them.
.claude/skills/*
!.claude/skills/README.md
!.claude/skills/conduit-*
!.claude/skills/agent-session-history-reader
!.claude/skills/vendor-cli-adapter-audit

# Remotion/animations node_modules
animations/node_modules/

# Marketing site build artifacts
marketing/.next/
marketing/node_modules/

# agent-runner compiled binary (build artifact, not source)
daemon/agent-runner/agent-runner

# push-backend compiled binaries
daemon/push-backend/push-backend
daemon/push-backend/push-backend-linux

# conduitd compiled binaries (distributed via GitHub Releases, not git)
daemon/conduitd/conduitd
daemon/conduitd/conduitd-macos
daemon/conduitd/conduitd-linux-amd64
daemon/conduitd/conduitd-linux-arm64
daemon/conduitd/conduitd-darwin-arm64

# conduitd release build artifacts
daemon/conduitd/dist/

# Root npm artifacts (this repo uses bun; root node_modules/package-lock/package are accidental)
/node_modules/
/package-lock.json
/package.json

# Serena MCP cache (tooling artifact, not source)
.serena/

# Temporary screenshots / scratch captures
.tmp-*.png
.tmp-*
.design-shots/

# Git worktrees
.worktrees/
