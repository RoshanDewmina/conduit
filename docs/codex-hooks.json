{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.codex/hooks/lancer-hook.sh",
            "timeout": 150,
            "statusMessage": "Waiting for Lancer approval"
          }
        ]
      }
    ]
  }
}
